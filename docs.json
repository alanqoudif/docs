              "quickstart",
              "platform/glossary"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/architecture",
              "features/artifacts",
              "features/export",
              "features/memory-and-swarm"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/overview",
              "agents/atlas",
              "agents/salem",
              "agents/specialists"
            ]
          },
          {
            "group": "Development and Operations",
            "pages": [
              "development",
              "developers/agent-tools",
              "developers/data-model",
              "operations/deployment"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction",
              "developers/api-overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Mibyan",
          "href": "https://mibyanai.com",
          "icon": "book-open-cover"
