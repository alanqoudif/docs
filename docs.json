{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mibyan / Atlas Swarm Core One",
  "colors": {
    "primary": "#F97316",
    "light": "#FB923C",
    "dark": "#EA580C"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
